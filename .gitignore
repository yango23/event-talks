# pyenv
#   For a library or app, you might want to share your .python-version.
#   For an app, this is files created by pyenv.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if delegates have different OS, lock file
#   might conflict.
# Pipfile.lock

# poetry
#   Poetry uses pyproject.toml and poetry.lock to manage dependencies
#   poetry.lock is typically committed

# pdm
#   PDM uses pyproject.toml and pdm.lock to manage dependencies
#   pdm.lock is typically committed
.pdm-plugins/
.pdm-python

